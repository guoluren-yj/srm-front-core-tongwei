  "scripts": {
    "start": "cross-env NODE_OPTIONS=--max_old_space_size=8192 NODE_PROFILE=development hzero-cli start",
    "build": "cross-env NODE_OPTIONS=--max_old_space_size=10240 NODE_PROFILE=production BUILD_DIST_PATH=./srm-dist BUILD_SKIP_PARENT=true hzero-cli build --only-build-micro",
    "build:analyze": "cross-env ANALYZE=true hzero-cli build --only-build-micro",
    "test": "jest --config .jest.js --cache=false",
    "test:update": "jest --config .jest.js --cache=false -u",
    "test-node": "jest --config .jest.node.js --cache=false",
    "lint": "npm run lint:script && npm run lint:demo && npm run lint:style",
    "lint:script": "eslint **/*.{js,jsx,ts,tsx} --ext '.js,.jsx,.ts,.tsx'",
    "lint:md": "remark components/",
    "lint:demo": "cross-env RUN_ENV=DEMO eslint components/*/demo/*.md --ext '.md'",
    "lint:style": "stylelint {components,components-pro}/**/*.less --syntax less",
    "lint-fix": "npm run lint-fix:script && npm run lint-fix:demo && npm run lint-fix:style",
    "lint-fix:script": "npm run lint:script -- --fix",
    "lint-fix:demo": "npm run lint:demo -- --fix",
    "lint-fix:style": "npm run lint:style -- --fix",
    "sort-api": "node ./scripts/sort-api-table.js",
    "transpile": "gulp compile && node ./tests/dekko/lib.test.js && node ./scripts/prepub",
    "pub": "npm run transpile && npm publish --with-tools",
    "prepublish": "gulp guard",
    "authors": "git log --format='%aN <%aE>' | sort -u | grep -v 'hand-china.com' > AUTHORS",
    "prettier": "prettier -c --write '**/*'",
    "pretty-quick": "pretty-quick"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "npm run lint:script"
    ],
    "{components,components-pro}/**/*.less": [
      "npm run lint:style"
    ],
    "components/*/demo/*.md": [
      "npm run lint:demo",
      "git add"
    ]
  },
  "sideEffects": [
    "dist/*",
    "es/**/style/*",
    "lib/**/style/*",
    "pro/es/**/style/*",
    "pro/lib/**/style/*",
    "*.less"
  ],
  "browserslist": [
    "last 2 version",
    "Firefox ESR",
    "> 1%",
    "ie >= 9"
  ]
}
