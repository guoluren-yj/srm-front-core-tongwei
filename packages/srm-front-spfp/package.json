{
  "name": "srm-front-spfp",
  "devDependencies": {
    "@babel/cli": "^7.17.6",
    "@babel/core": "^7.17.5",
    "@babel/preset-env": "^7.17.10",
    "@babel/preset-react": "^7.16.7",
    "@typescript-eslint/eslint-plugin": "^4.17.0",
    "@typescript-eslint/parser": "^4.17.0",
    "babel-loader": "8.0.5",
    "choerodon-ui": "1.5.4-webpack5",
    "conventional-changelog-cli": "^2.0.12",
    "hzero-front": "1.5.8-webpack5-1",
    "hzero-ui": "2.0.0-webpack5",
    "levenary": "^1.1.1",
    "standard-version": "^5.0.2",
    "yarn": "^1.13.0",
    "typescript": "^4.8.3",
    "eslint-plugin-react-hooks": "^4.6.0"
  },
  "dependencies": {
    "choerodon-ui": "1.5.4-webpack5",
    "choerodon-ui-font": "0.2.8",
    "react": "16.12.0",
    "react-dom": "16.12.0",
    "react-router": "4.3.1",
    "react-router-dom": "4.3.1",
    "srm-front-boot": "1.28.0-webpack5-2",
    "srm-front-cuz": "1.5.0-webpack5"
  },
  "peerDependencies": {
    "hzero-front": "1.5.8-webpack5-1",
    "srm-front-boot": "1.28.0-webpack5-2",
    "srm-front-cuz": "1.5.0-webpack5"
  },
  "resolutions": {
    "@babel/cli": "^7.17.6",
    "@babel/core": "^7.17.5",
    "@babel/preset-env": "^7.17.10",
    "@babel/preset-react": "^7.16.7",
    "hzero-boot": "3.0.0-zhenyun.14",
    "hzero-cli": "3.0.0-zhenyun.11",
    "hzero-webpack-scripts": "3.0.0-zhenyun.10",
    "react": "16.12.0",
    "choerodon-ui": "1.5.4-webpack5",
    "choerodon-ui-font": "0.2.8",
    "react-router": "4.3.1",
    "react-router-dom": "4.3.1",
    "react-dom": "16.12.0",
    "hzero-front": "1.5.8-webpack5-1",
    "jsencrypt": "3.0.0-rc.1",
    "srm-front-boot": "1.28.0-webpack5-1",
    "@hzero-front-ui/cfg": "^2.0.18",
    "@hzero-front-ui/c7n-ui": "^2.0.18",
    "@hzero-front-ui/hzero-ui": "^2.0.18",
    "conventional-changelog": "~3.0.6",
    "mini-css-extract-plugin": "0.4.1",
    "optimize-css-assets-webpack-plugin": "5.0.3",
    "url-loader": "1.1.2",
    "css-loader": "4.3.0",
    "file-loader": "6.2.0",
    "colors": "1.4.0"
  },
  "description": "srm-front-spfp",
  "author": "",
  "version": "1.62.0",
  "eslintConfig": {
    "extends": "react-app"
  },
  "publishConfig": {
    "registry": "https://nexus.going-link.com/repository/zhenyun-npm-source/"
  },
  "scripts": {
    "start": "cross-env NODE_PROFILE=development MULTIPLE_SKIN_ENABLE=true hzero-cli start",
    "build": "cross-env NODE_OPTIONS=--max_old_space_size=4096 NODE_PROFILE=production BUILD_DIST_PATH=./srm-dist BUILD_SKIP_PARENT=true hzero-cli build --only-build-micro",
    "lint": "eslint --ext .js src && npm run lint:style",
    "lint:fix": "eslint --quiet --fix --ext .js src && npm run lint:style",
    "lint:style": "stylelint \"src/**/*.less\" --syntax less",
    "prettier": "prettier --write ./src/**/**/**/*",
    "transpile": "rm -rf ./lib && tsc && cross-env NODE_ENV=production BABEL_ENV=production npx babel -x .js,.ts,.jsx,.tsx src --out-dir lib --copy-files --ignore 'src/**/*.spec.js','src/**/*.test.js'",
    "tree": "tree -I node_modules -L 3",
    "lint-staged": "lint-staged",
    "test": "hzero-cli test",
    "changelog": "node node_modules/.bin/conventional-changelog -p angular -i CHANGELOG.md -s -r 0 && git add CHANGELOG.md",
    "release": "standard-version",
    "commit": "git-cz",
    "codeScan": "hzero codeScan"
  },
  "files": [
    "lib",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint-staged",
      "post-merge": "git submodule update",
      "post-checkout": "git submodule update",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "optionalDependencies": {
    "puppeteer": "^1.1.1"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 10",
    "not op_mini all"
  ],
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts"
    ],
    "resolver": "jest-pnp-resolver",
    "setupFiles": [
      "react-app-polyfill/jsdom"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.{js,jsx,ts,tsx}",
      "<rootDir>/src/**/?(*.)(spec|test).{js,jsx,ts,tsx}"
    ],
    "testEnvironment": "jsdom",
    "testURL": "http://localhost",
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "<rootDir>/node_modules/babel-jest",
      "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
      "^(?!.*\\.(js|jsx|ts|tsx|css|json)$)": "<rootDir>/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|ts|tsx)$",
      "^.+\\.module\\.(css|sass|scss)$"
    ],
    "moduleNameMapper": {
      "^react-native$": "react-native-web",
      "^.+\\.module\\.(css|sass|scss)$": "identity-obj-proxy"
    },
    "moduleFileExtensions": [
      "web.js",
      "js",
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "json",
      "web.jsx",
      "jsx",
      "node"
    ],
    "watchPlugins": [
      "<rootDir>/node_modules/jest-watch-typeahead/filename.js",
      "<rootDir>/node_modules/jest-watch-typeahead/testname.js"
    ]
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": "eslint --quiet --fix --ext .js",
    "src/**/*.less": "stylelint --syntax less",
    "src/**/*.{js,jsx,less}": [
      "prettier --write",
      "git add"
    ]
  }
}