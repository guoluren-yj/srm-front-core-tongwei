  },
  "scripts": {
    "start": "cross-env PORT=8001 NODE_OPTIONS=--max_old_space_size=8192 NODE_PROFILE=development hzero-cli start",
    "build": "cross-env NODE_OPTIONS=--max_old_space_size=10240 NODE_PROFILE=production BUILD_DIST_PATH=./srm-dist BUILD_SKIP_PARENT=true hzero-cli build --only-build-micro",
    "lint": "npm run lint:script && npm run lint:demo && npm run lint:style",
    "lint:script": "eslint **/*.{js,jsx,ts,tsx} --ext '.js,.jsx,.ts,.tsx'",
    "lint:md": "remark components/",
    "lint:demo": "cross-env RUN_ENV=DEMO eslint components/*/demo/*.md --ext '.md'",
    "lint:style": "stylelint components/**/*.less --syntax less",
    "lint-fix": "eslint --fix --ext '.js,.jsx' components",
    "lint-fix:script": "eslint --fix **/*.{js,jsx,ts,tsx} --ext '.js,.jsx,.ts,.tsx'",
    "lint-fix-bak": "npm run lint-fix:code && npm run lint-fix:demo",
    "lint-fix:code": "eslint --fix tests scripts components ./.eslintrc.js ./webpack.config.js --ext '.js,.jsx'",
    "lint-fix:demo": "eslint-tinker ./components/*/demo/*.md",
    "sort-api": "node ./scripts/sort-api-table.js",
    "transpile": "gulp compile && node ./tests/dekko/lib.test.js && node ./scripts/prepub",
    "pub": "npm run transpile && npm publish --tag=beta",
    "lint-staged": "lint-staged",
    "lint-staged:ts": "eslint **/*.{js,jsx,ts,tsx} --ext '.js,.jsx,.ts,.tsx'",
    "lint-staged:es": "eslint ./.eslintrc.js",
    "lint-staged:demo": "cross-env RUN_ENV=DEMO eslint --ext '.md'"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "{tests,scripts,components}/**/*.{js,jsx,ts,tsx}": [
      "npm run lint-staged:es"
    ],
    "components/**/*.less": [
      "npm run lint:style"
    ],
    "components/*/demo/*.md": [
      "npm run lint:demo"
    ]
  },
  "sideEffects": [
    "es/**/style/*",
    "lib/**/style/*"
  ],
  "browserslist": [
    "last 2 version",
    "Firefox ESR",
    "> 1%",
    "ie >= 9"
  ]
}
